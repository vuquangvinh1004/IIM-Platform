  "supports_state_restore": true,
  "supports_export": false,
  "icon": "assets/icon.png",
  "data_contract_version": "1.0.0",
  "default_settings": {
    "theme_variant": "default"
  },
  "capabilities": [
    "plot.2d",
    "compute.statistics",
    "interactive.controls"
  ],
  "ui": {
    "min_width": 960,
    "min_height": 600,
    "layout_mode": "split"
  }
